# URL base de la API. No incluir /api/v1 porque el cliente lo añade internamente.
VITE_API_BASE_URL=https://padelstack-api.onrender.com

# Variables públicas de Firebase Web.
# Se obtienen en Firebase Console > Project settings > General > Your apps > Web app.
# No usar firebase-service-account.json en frontend.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
